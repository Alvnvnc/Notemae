{
  "name": "scentsphere-fe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SPA React + TypeScript untuk panduan dupe parfum, dilayani Express dengan SSR.",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "dev": "node --watch-path=./server.ts server.ts",
    "build": "node scripts/licenses.mjs && vite build && vite build --ssr src/react/entry-server.tsx --outDir dist/server",
    "licenses": "node scripts/licenses.mjs",
    "start": "NODE_ENV=production node server.ts",
    "typecheck": "tsc --noEmit",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "gsap": "^3.15.0",
    "http-proxy-middleware": "^3.0.5",
    "lenis": "^1.3.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}

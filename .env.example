# Shared internal credential. Replace before any non-local deployment.
SERVICE_SHARED_SECRET=change-me-before-production

# Qwen Cloud (OpenAI-compatible endpoint). Get a key from
# https://home.qwencloud.com/api-keys
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_PROFILE_MODEL=
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024
QWEN_THINKING=1

# YouTube Data API v3 (official). Used only for fragrance-review discovery;
# search.list costs 100 quota units per call (default quota 10,000/day).
# Leave empty to keep the YouTube source disabled.
YOUTUBE_API_KEY=

# LLM enrichment for sparse catalog records (reuses the Qwen-compatible
# endpoint above). Confidence-gated: unknown products are skipped, not guessed.
ENRICHMENT_MAX_RECORDS_PER_RUN=60
ENRICHMENT_MIN_CONFIDENCE=0.7

# Renewable ingestion. Open Beauty Facts publishes ODbL nightly deltas.
AUTO_INGEST_ENABLED=true
AUTO_INGEST_INTERVAL_SECONDS=21600
AUTO_INGEST_RETRY_SECONDS=300
AUTO_INGEST_STARTUP_DELAY_SECONDS=15
OBF_BOOTSTRAP_FILES=14
OBF_MAX_FILES_PER_RUN=2
OBF_MAX_RECORDS_PER_RUN=500
SOURCE_USER_AGENT=ScentSphere/0.1 (replace with a project contact before production)
